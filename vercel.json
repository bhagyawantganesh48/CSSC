{
  "version": 2,
  "builds": [
    {
      "src": "quiz_backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",  "dest": "/quiz_backend/server.js" },
    { "src": "/",          "dest": "/frontend/index.html"    },
    { "src": "/(.*)",      "dest": "/frontend/$1"            }
  ]
}
